# ===========================================
# The BLX RealtyReal Estate Platform - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# ===========================================
# DATABASE (Prisma) + STORAGE (Supabase)
# ===========================================
# Properties, blogs, careers TEXT → Prisma Accelerate (DATABASE_URL)
# Property images / uploads → Supabase Storage (NEXT_PUBLIC_SUPABASE_URL below)
#
# DATABASE_URL = Prisma Accelerate URL from https://console.prisma.io (your live data)
DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_API_KEY"
# DIRECT_URL = Supabase Postgres (migrations only; optional future data sync)
DIRECT_URL="postgresql://postgres.gjpujedmzdthonncnwsg:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

 

    

# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
# JWT secret for token signing (generate a secure random string)
JWT_SECRET="your-super-secure-jwt-secret-key-here"

# NextAuth.js configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-here"

# Google OAuth (optional - for social login)
GOOGLE_OAUTH_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_OAUTH_SECRET="your-google-oauth-client-secret"

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
# Azure AD credentials for Microsoft Graph API (recommended)
AZURE_TENANT_ID="your-azure-tenant-id"
AZURE_CLIENT_ID="your-azure-client-id"
AZURE_CLIENT_SECRET="your-azure-client-secret"

# Default sender email address
EMAIL_FROM="Discoverblr@theblxrealty.com"

# Alternative: Gmail SMTP (if not using Azure)
# EMAIL_USER="your-email@gmail.com"
# EMAIL_PASS="your-gmail-app-password"

# ===========================================
# CLOUDINARY CONFIGURATION (Image Storage)
# ===========================================
# Cloudinary credentials for image uploads
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ===========================================
# SUPABASE CONFIGURATION (Alternative Image Storage)
# ===========================================
# Supabase credentials (if using Supabase instead of Cloudinary)
NEXT_PUBLIC_SUPABASE_URL="your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ===========================================
# GOOGLE MAPS API
# ===========================================
# Google Maps API Key
NEXT_PUBLIC_GOOGLE_MAPS_API=AIzaSyCz1LU_UDWuDH-81clruob05fCosjBuakk
GOOGLE_MAPS_API=AIzaSyCz1LU_UDWuDH-81clruob05fCosjBuakk

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
# Application URL (for production, use your domain)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"

# ===========================================
# PRODUCTION OVERRIDES (Optional)
# ===========================================
# Uncomment and configure for production deployment
# DATABASE_URL="postgresql://prod_user:prod_pass@prod_host:5432/prod_db"
# NEXTAUTH_URL="https://your-domain.com"
# NEXT_PUBLIC_APP_URL="https://your-domain.com"
# NODE_ENV="production"
